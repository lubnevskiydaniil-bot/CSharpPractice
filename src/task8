//https://www.hackerrank.com/challenges/migratory-birds/problem
public static int migratoryBirds(List<int> arr)
{
    int[] count = new int[6]; // индексы 1–5

    foreach (int bird in arr)
    {
        count[bird]++;
    }

    int maxCount = 0;
    int result = 0;

for (int i = 1; i <= 5; i++)
    {
        if (count[i] > maxCount)
        {
            maxCount = count[i];
            result = i;
        }
    }

    return result;
}
